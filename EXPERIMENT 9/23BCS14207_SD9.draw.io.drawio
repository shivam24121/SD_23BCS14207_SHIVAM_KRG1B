        <mxCell id="w3Z3quPdJxVzz6ZpwIV2-42" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" value="1. Search Functionality: Users must be able to discover events using filters - Event Title, City / Location, and specific Date of the show." vertex="1">
          <mxGeometry height="30" width="1200" x="450" y="-2250" as="geometry" />
        </mxCell>
        <mxCell id="w3Z3quPdJxVzz6ZpwIV2-43" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" value="2. Event Information Display: Users must be able to view comprehensive details - No. of Seats (available vs. occupied), Description, and Metadata (cast, duration, language, ratings)." vertex="1">
          <mxGeometry height="30" width="1200" x="450" y="-2190" as="geometry" />
        </mxCell>
        <mxCell id="w3Z3quPdJxVzz6ZpwIV2-44" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" value="3. Booking Execution: The system must allow a user to select a seat and complete a transaction to Book a Ticket." vertex="1">
          <mxGeometry height="30" width="1200" x="450" y="-2130" as="geometry" />
        </mxCell>
        <mxCell id="w3Z3quPdJxVzz6ZpwIV2-45" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=14;fontStyle=1;strokeColor=default;fillColor=none;" value="Non-Functional Requirements" vertex="1">
          <mxGeometry height="40" width="280" x="450" y="-2050" as="geometry" />
        </mxCell>
