          <mxGeometry height="30" width="1200" x="450" y="-1970" as="geometry" />
        </mxCell>
        <mxCell id="w3Z3quPdJxVzz6ZpwIV2-47" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" value="2. CAP Theorem:" vertex="1">
          <mxGeometry height="30" width="1200" x="450" y="-1910" as="geometry" />
        </mxCell>
        <mxCell id="w3Z3quPdJxVzz6ZpwIV2-48" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" value="Search / View Aspect: High Availability - better to show slightly stale data than an error page. (Eventual Consistency)" vertex="1">
          <mxGeometry height="30" width="1200" x="510" y="-1870" as="geometry" />
        </mxCell>
        <mxCell id="w3Z3quPdJxVzz6ZpwIV2-49" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontFamily=Helvetica;fontSize=12;" value="Booking Aspect: High Consistency - two users should never be able to book the exact same seat simultaneously. (Strong Consistency)" vertex="1">
          <mxGeometry height="30" width="1200" x="510" y="-1830" as="geometry" />
        </mxCell>
