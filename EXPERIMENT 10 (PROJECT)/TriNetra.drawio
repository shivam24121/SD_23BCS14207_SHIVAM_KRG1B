        <mxCell id="doc-fr" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=18;fontStyle=1;strokeColor=#0f172a;fillColor=#f8fafc;" value="1. Functional Requirements (FRs)" vertex="1">
          <mxGeometry height="50" width="400" x="200" y="-2300" as="geometry" />
        </mxCell>
        <mxCell id="doc-fr-text" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontFamily=Helvetica;fontSize=15;lineHeight=1.5;" value="• &lt;b&gt;Monitoring:&lt;/b&gt; Real-time tactical map (friendly &amp; hostile).&lt;br&gt;• &lt;b&gt;Deployment:&lt;/b&gt; Launch assets from airbases/fleets.&lt;br&gt;• &lt;b&gt;Detection:&lt;/b&gt; Radar tracking &amp; AI trajectory prediction.&lt;br&gt;• &lt;b&gt;Execution:&lt;/b&gt; Manual intercepts or Auto-Kill SAM zones.&lt;br&gt;• &lt;b&gt;Replay:&lt;/b&gt; Event logging for After-Action Reviews." vertex="1">
          <mxGeometry height="150" width="2000" x="200" y="-2230" as="geometry" />
        </mxCell>
        <mxCell id="doc-nfr" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=18;fontStyle=1;strokeColor=#0f172a;fillColor=#f8fafc;" value="2. Non-Functional Requirements (NFRs)" vertex="1">
          <mxGeometry height="50" width="400" x="200" y="-2050" as="geometry" />
        </mxCell>
        <mxCell id="doc-nfr-text" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontFamily=Helvetica;fontSize=15;lineHeight=1.5;" value="• &lt;b&gt;Scale:&lt;/b&gt; 500–1000+ simultaneous entities.&lt;br&gt;• &lt;b&gt;Latency:&lt;/b&gt; &amp;lt;100ms UI updates via WebSockets.&lt;br&gt;• &lt;b&gt;Consistency:&lt;/b&gt; Strong consistency for combat logic.&lt;br&gt;• &lt;b&gt;Availability:&lt;/b&gt; Fault-tolerant event-driven architecture." vertex="1">
          <mxGeometry height="120" width="2000" x="200" y="-1980" as="geometry" />
        </mxCell>
        <mxCell id="doc-api" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=18;fontStyle=1;strokeColor=#0f172a;fillColor=#f8fafc;" value="3. API Design &amp; Domain Entities" vertex="1">
          <mxGeometry height="50" width="400" x="200" y="-1800" as="geometry" />
        </mxCell>
        <mxCell id="doc-api-text" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontFamily=Helvetica;fontSize=15;lineHeight=1.5;" value="&lt;b&gt;Deployment APIs (REST):&lt;/b&gt;&lt;br&gt;POST /deploy/aircraft&lt;br&gt;POST /deploy/naval-fleet&lt;br&gt;POST /deploy/sam-zone&lt;br&gt;&lt;br&gt;&lt;b&gt;Real-Time Sockets:&lt;/b&gt;&lt;br&gt;/ws/airspace (Telemetry)&lt;br&gt;/ws/events (Combat)" vertex="1">
          <mxGeometry height="160" width="400" x="200" y="-1730" as="geometry" />
        </mxCell>
        <mxCell id="doc-entities-text" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontFamily=Helvetica;fontSize=15;lineHeight=1.5;" value="&lt;b&gt;Friendly Entities:&lt;/b&gt; Aircraft, DroneSwarm, NavalFleet, Submarine&lt;br&gt;&lt;b&gt;Hostile Entities:&lt;/b&gt; EnemyThreat&lt;br&gt;&lt;b&gt;Infra &amp; Operations:&lt;/b&gt; Airbase, RadarStation, SAMZone, Mission, EventLog" vertex="1">
          <mxGeometry height="100" width="800" x="700" y="-1730" as="geometry" />
        </mxCell>
        <mxCell id="doc-db" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Helvetica;fontSize=18;fontStyle=1;strokeColor=#0f172a;fillColor=#f8fafc;" value="4. Database Schema &amp; Storage Architecture" vertex="1">
          <mxGeometry height="50" width="450" x="200" y="-1500" as="geometry" />
        </mxCell>
        <mxCell id="doc-db-text" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontFamily=Helvetica;fontSize=15;lineHeight=1.5;" value="&lt;b&gt;PostgreSQL (Persistent Truth):&lt;/b&gt; Relational tables for users, airbases, missions, naval_fleets, submarines. Loaded heavily on system init.&lt;br&gt;&lt;b&gt;PostgreSQL + TimescaleDB (Event Sourcing):&lt;/b&gt; &#39;event_logs&#39; table stores high-volume time-series data of all Kafka events for historical replay capability.&lt;br&gt;&lt;b&gt;Redis Cluster (In-Memory Hot State):&lt;/b&gt; Stores geospatial coords of aircraft and live SAM ranges. Allows O(1) reads for the WebSocket gateway to blast map updates instantly." vertex="1">
          <mxGeometry height="140" width="2000" x="200" y="-1430" as="geometry" />
        </mxCell>
        <mxCell id="3XtBrMZmQkqhb981gPZJ-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="90" width="90" x="990" y="-430" as="geometry" />
        </mxCell>
        <mxCell id="3XtBrMZmQkqhb981gPZJ-4" parent="1" style="sketch=0;pointerEvents=1;shadow=0;dashed=0;html=1;strokeColor=none;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;align=center;fillColor=#505050;shape=mxgraph.mscae.intune.device_history" value="" vertex="1">
          <mxGeometry height="80" width="70" x="1000" y="-430" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
